# ========================================
# CREDENCIALES DEMO (CAMBIAR EN PRODUCCIÓN)
# ========================================

# Master Admin
DEMO_MASTER_EMAIL=admin@sistematesis.com
DEMO_MASTER_PASSWORD=Admin@123456

# Org Admins (formato: email1,email2,...)
DEMO_ORG_ADMINS=admin@techinnovations.local,admin@retailcorp.local

# Viewers (formato: email1,email2,...)
DEMO_VIEWERS=user1@techinnovations.local,user2@techinnovations.local
# Streamlit Config
STREAMLIT_SERVER_HEADLESS=false
# ==================== SUPERADMIN CONFIGURATION ====================
# List of emails (comma-separated) that have superadmin privileges (Creators/Administrators)
# Superadmins can:
#   - Create new organizations
#   - Create admin users for organizations
#   - Manage users globally (assign, remove, delete)
#   - Access the Superadmin Panel (🏆 tab in dashboard)
# 
# Example: SUPERADMIN_EMAILS=admin@company.com,creator@company.com,founder@company.com
SUPERADMIN_EMAILS=