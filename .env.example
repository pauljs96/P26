# Supabase Configuration
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=xxxxx

# AWS S3 Configuration (para almacenar CSV uploads en la nube)
# Dejar comentado para usar fallback (session storage/local)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_S3_REGION=us-east-1
# Streamlit Config
STREAMLIT_SERVER_HEADLESS=false
# ==================== SUPERADMIN CONFIGURATION ====================
# List of emails (comma-separated) that have superadmin privileges (Creators/Administrators)
# Superadmins can:
#   - Create new organizations
#   - Create admin users for organizations
#   - Manage users globally (assign, remove, delete)
#   - Access the Superadmin Panel (🏆 tab in dashboard)
# 
# Example: SUPERADMIN_EMAILS=admin@company.com,creator@company.com,founder@company.com
SUPERADMIN_EMAILS=